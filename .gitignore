# --- Local environments & secrets ---
.env
.env.*
!.env.example
.venv/
venv/
__pycache__/
*.py[cod]
*$py.class
.Python

# --- JS / OpenCode plugin install cache (when developing locally) ---
node_modules/

# --- Build / dist ---
dist/
build/
*.egg-info/

# --- OS ---
.DS_Store
Thumbs.db

